{
  "name": "micro/api-gateway",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "guzzlehttp/guzzle": "^7.0",
    "laravel/passport": "^12.0"
  },
  "config": {
    "platform": {
      "php": "8.2.32"
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8000 -t public"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
